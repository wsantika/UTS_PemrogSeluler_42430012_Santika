<?xml version="1.0" encoding="utf-8"?>

<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#EEF4FF">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/main"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingBottom="30dp">

        <!-- HEADER -->

        <LinearLayout
            android:id="@+id/header"
            android:orientation="vertical"
            android:padding="24dp"
            android:background="#2F6BFF"
            android:layout_width="0dp"
            android:layout_height="160dp"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent">

            <TextView
                android:id="@+id/tvGreeting"
                android:text="Selamat bertugas"
                android:textSize="22sp"
                android:textStyle="bold"
                android:textColor="@android:color/white"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"/>

            <TextView
                android:text="Silakan masukkan data evaluasi kelas hari ini."
                android:textColor="@android:color/white"
                android:textSize="14sp"
                android:layout_marginTop="6dp"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"/>

        </LinearLayout>

        <!-- CARD INPUT -->

        <androidx.cardview.widget.CardView
            android:id="@+id/cardInput"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_margin="20dp"
            app:cardCornerRadius="20dp"
            app:cardElevation="8dp"
            app:layout_constraintTop_toBottomOf="@id/header"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent">

            <LinearLayout
                android:orientation="vertical"
                android:padding="24dp"
                android:layout_width="match_parent"
                android:layout_height="wrap_content">

                <EditText
                    android:id="@+id/etJumlah"
                    android:hint="Jumlah Mahasiswa"
                    android:inputType="number"
                    android:background="@drawable/input_style"
                    android:padding="14dp"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"/>

                <EditText
                    android:id="@+id/etTugas"
                    android:hint="Nilai Tugas"
                    android:inputType="numberDecimal"
                    android:background="@drawable/input_style"
                    android:padding="14dp"
                    android:layout_marginTop="12dp"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"/>

                <EditText
                    android:id="@+id/etKeaktifan"
                    android:hint="Nilai Keaktifan"
                    android:inputType="numberDecimal"
                    android:background="@drawable/input_style"
                    android:padding="14dp"
                    android:layout_marginTop="12dp"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"/>

                <EditText
                    android:id="@+id/etUTS"
                    android:hint="Nilai UTS"
                    android:inputType="numberDecimal"
                    android:background="@drawable/input_style"
                    android:padding="14dp"
                    android:layout_marginTop="12dp"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"/>

                <EditText
                    android:id="@+id/etUAS"
                    android:hint="Nilai UAS"
                    android:inputType="numberDecimal"
                    android:background="@drawable/input_style"
                    android:padding="14dp"
                    android:layout_marginTop="12dp"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"/>

                <Button
                    android:id="@+id/btnProses"
                    android:text="PROSES DATA"
                    android:textColor="@android:color/white"
                    android:backgroundTint="#3D7BFF"
                    android:layout_marginTop="18dp"
                    android:layout_width="match_parent"
                    android:layout_height="55dp"/>

            </LinearLayout>

        </androidx.cardview.widget.CardView>

        <!-- CARD HASIL -->

        <androidx.cardview.widget.CardView
            android:id="@+id/cardHasil"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="20dp"
            android:layout_marginTop="10dp"
            app:cardCornerRadius="20dp"
            app:cardElevation="8dp"
            app:layout_constraintTop_toBottomOf="@id/cardInput"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent">

            <TextView
                android:id="@+id/tvHasil"
                android:text="Menunggu data diproses..."
                android:textSize="16sp"
                android:textColor="#374151"
                android:padding="24dp"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"/>

        </androidx.cardview.widget.CardView>

    </androidx.constraintlayout.widget.ConstraintLayout>

</ScrollView>